      <manipulate id="a1" label="Create Configuration">
        <code># --- Helpers ---
def map_gm_factor(diff)
  case diff
  when "Easy" then 0.5
  when "Normal" then 1.0
  when "Hard" then 2.0
  when "Deadly" then 3.0
  end
end

def map_env_factor(diff)
  case diff
  when "Easy" then 0.5
  when "Normal" then 1.0
  when "Hard" then 1.5
  when "Deadly" then 2.0
  end
end

# --- Set Up Configuration ---
data.configuration = data.config_template

gm_factor = map_gm_factor(data.enemy_difficulty)
env_factor = map_env_factor(data.environment_difficulty)

data.configuration["gm_factor"] = gm_factor
data.configuration["enemy_dc"] = 10 + (4 * gm_factor)
data.configuration["max_enemies"] = data.number_of_players.to_i
data.configuration["fear"] = gm_factor * data.number_of_players.to_i
data.configuration["enemy_spawn_chance"] = 32 * gm_factor

data.configuration["enemy_hp"] = (20 * gm_factor).ceil
data.configuration["enemy_ac"] = (15 + (3 * gm_factor).ceil)
data.configuration["enemy_init_bonus"] = (3 * gm_factor).ceil
data.configuration["enemy_attack_bonus"] = (4 * gm_factor).ceil

data.configuration["env_factor"] = env_factor
data.configuration["env_dc"] = 10 + (4 * env_factor)
data.configuration["trap_chance"] = 30 * env_factor</code>
