      <manipulate id="a3" label="Create Traps">
        <code>data.traps = data.trap_template
env_dc = data.configuration["env_dc"].to_i

data.traps.each do |trap|
  next unless trap.is_a?(Hash)
  trap["dc"] = env_dc if trap["dc"].nil?
end</code>
