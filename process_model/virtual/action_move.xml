          <manipulate id="a2" label="Update Player Position and Conditions">
            <code># --- Helper ---
def find_cell(game_state, r, c)
  game_state.flatten.find do |cell|
    g = cell["global"]
    g &amp;&amp; g[0].to_i == r.to_i &amp;&amp; g[1].to_i == c.to_i
  end
end

# --- Initialize Cell Variables ---
res = data.result

if res.is_a?(String) &amp;&amp; res.strip.start_with?('[')
  res = JSON.parse(res)
end

if res.is_a?(String) &amp;&amp; res.include?(',')
  res = res.split(',').map(&amp;:to_i)
end

old_r, old_c = data.current_player["position"]
new_r, new_c = res

# --- Find the Grid Cells ---
old_cell = find_cell(data.game_state, old_r, old_c)
new_cell = find_cell(data.game_state, new_r, new_c)

# --- Update current_player position ---
data.current_player["position"] = [new_r, new_c]

# --- Update current_player conditions ---
cur_cond = (data.current_player["conditions"] || []).dup
cur_cond &lt;&lt; "moved" unless cur_cond.include?("moved")

# --- Update game_state occupancy ---
old_cell["occupied"] = nil if old_cell
new_cell["occupied"] = data.current_player["id"].to_s

# --- Handle end-condition ---
end_effect_map = {
  "rogue" =&gt; "rogueE",
  "barbarian" =&gt; "barbarianE",
  "wizard" =&gt; "wizardE",
  "cleric" =&gt; "clericE"
}

effect_here  = new_cell["effect"]
expected_effect = end_effect_map[data.current_player["id"].to_s]

if expected_effect &amp;&amp; effect_here.to_s == expected_effect.to_s
  cur_cond &lt;&lt; "reached_end" unless cur_cond.include?("reached_end")
else
  cur_cond.delete("reached_end")
end

data.current_player["conditions"] = cur_cond

# --- Propagate changes into player_data &amp; initiative_order ---
[data.initiative_order, data.player_data].each do |arr|
  pl = arr.find { |p| p["id"].to_s == data.current_player["id"].to_s }
  next unless pl

  pl["position"] = [new_r, new_c]
  pl["conditions"] = cur_cond.dup
end</code>
