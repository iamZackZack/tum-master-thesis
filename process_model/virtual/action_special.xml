      <choose mode="exclusive" label="">
        <alternative condition="data.special == true">
          <manipulate id="a3" label="Handle Special Action Conditions">
            <code># --- Variables ---
action_id = data.current_player["chosen_action"].to_i

skills = data.current_player["skills"] || []
skill  = skills.find { |s| (s["id"] || 0).to_i == action_id } || {}

m_cost = (skill["m_cost"] || 0).to_i
a_cost = (skill["a_cost"] || 0).to_i

mana = data.current_player["mana"].to_i
adr  = data.current_player["adrenaline"].to_i

conds = (data.current_player["conditions"] || []).map(&amp;:to_s)

# --- Apply Special Action Results ---

case action_id
when 14
  max_move = data.current_player["max_movement"].to_i
  cur_move = data.current_player["current_movement"].to_i
  data.current_player["current_movement"] = cur_move + max_move

  data.current_player["action_available"] = false
when 3, 9, 11
  data.current_player["mana"] = [mana - m_cost, 0].max
  data.current_player["adrenaline"] = [adr - a_cost, 0].max

  case action_id
  when 3
    conds &lt;&lt; "raging" unless conds.include?("raging")
  when 9
    conds &lt;&lt; "hidden" unless conds.include?("hidden")
  when 11
    conds &lt;&lt; "shielded" unless conds.include?("shielded")
  end

  data.current_player["b_action_available"] = false
end

data.current_player["conditions"] = conds</code>
