                      <manipulate id="a20" label="Rule: Traps Effecting Insanity Increases Insanity">
                        <code>choice = data.player_action_choice.to_s
effect = data.trap["effect_on"].to_s

dice_n = data.trap["no_of_dice"].to_i
die_s  = data.trap["die"].to_s
die_sz = die_s.sub(/^d/i,'').to_i

damage = 0
