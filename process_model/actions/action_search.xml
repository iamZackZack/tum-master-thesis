              <manipulate id="a10" label="Determine Trap Parameters">
                <code># --- Helper ---

def find_ability(player, ab_id)
  abs = player["abilities"]
  return nil unless abs.is_a?(Array)
  abs.find { |a| (a["id"] || "").to_s.downcase == ab_id.to_s.downcase }
end

if data.player_action_choice.to_s == "Deactivate"
  data.title = data.trap["on_deactivate_title"]
  data.message = data.trap["on_deactivate_message"]

  ab_id = data.trap["deactivate_ability"].to_s
  ab = find_ability(data.current_player, ab_id)
  mod = ab ? ab["mod"].to_i : 0

  data.max_roll = 20 + mod
else
  data.title = data.trap["on_avoid_title"]
  data.message = data.trap["on_avoid_message"]

  ab_id = data.trap["dodge_ability"].to_s
  ab = find_ability(data.current_player, ab_id)
  st = ab ? ab["saving_throw"].to_i : 0

  data.max_roll = 20 + st
end</code>
