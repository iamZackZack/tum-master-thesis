max_ins = data.current_player["max_insanity"].to_i
data.current_player["insanity"] = [data.current_player["insanity"].to_i + damage, max_ins].min

data.title = (choice == "Deactivate") ? data.trap["on_failed_deactivate"] : data.trap["on_failed_avoid"]
data.message = "You took #{damage} #{effect} damage from the #{data.trap["title"]}..."</code>
                        <annotations>
