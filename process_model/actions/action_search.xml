          <manipulate id="a2" label="Determine Search Result">
            <code>conds = data.current_player["conditions"].map(&amp;:to_s)

nothing_prob = 0
item_prob    = 0
trap_prob    = 0

unless conds.include?("moved")
  nothing_prob = 100
  item_prob    = 0
  trap_prob    = 0
else
  if data.player_roll.to_i &lt; data.configuration["env_dc"].to_i
    trap_prob = data.configuration["trap_chance"].to_i
    nothing_prob = 100 - trap_prob
    item_prob = 0
    data.configuration["fear"] = 
      data.configuration["fear"].to_i + (2 * data.configuration["gm_factor"].to_i)
  else
    trap_prob = data.configuration["trap_chance"].to_i
    remainder = 100 - trap_prob
    nothing_prob = (remainder / 2).ceil
    item_prob = (remainder / 2).ceil
  end
end

x = rand(1..100)

if x &lt;= nothing_prob
  data.result = 0
elsif x &lt;= (nothing_prob + item_prob)
  data.result = 1
else
  data.result = 2
end

if data.current_player["id"].to_s == "cleric" || data.current_player["id"].to_s == "wizard"
  data.current_player["b_action_available"] = false
else
  data.current_player["action_available"] = false
end</code>
