def next_free_item_id(base_id, equipment)
  n = 1
  loop do
    candidate = "#{base_id}#{n}"
    return candidate unless equipment.include?(candidate)
    n += 1
  end
end

# --- Variables ---
item = data.items.sample
raw_id = item["id"]
base = raw_id.sub("#", "")

# --- Add item to player's equipment ---

new_item_id = next_free_item_id(base, data.current_player["equipment"])
data.current_player["equipment"] &lt;&lt; new_item_id

# --- Set Title &amp; Message
data.title   = "#, you found an item!"
data.message = item["description"]</code>
