                    <otherwise>
                      <manipulate id="a23" label="Rule: Avoided Traps Deal Half Damage">
                        <code># --- Variables ---

choice = data.player_action_choice.to_s
roll = data.player_roll.to_i
dc = data.trap["dc"].to_i
effect = data.trap["effect_on"].to_s
dice_n = data.trap["no_of_dice"].to_i
die_s  = data.trap["die"].to_s
die_sz = die_s.sub(/^d/i,'').to_i

# --- Roll damage ---
damage = 0
dice_n.times { damage += rand(1..die_sz) }
half = (damage / 2.0).ceil

if effect == "insanity"
  max_ins = data.current_player["max_insanity"].to_i
  data.current_player["insanity"] = [data.current_player["insanity"].to_i + half, max_ins].min
else
  data.current_player[effect] = [data.current_player[effect].to_i - half, 0].max
