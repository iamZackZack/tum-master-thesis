  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">
      <manipulate id="a2" label="Validate Movement Availability">
        <code>if data.current_player["current_movement"].to_i == 0
  data.reason = 0
  return
elsif data.current_player["conditions"].map(&amp;:to_s).include?("grappled")
  data.reason = 1
  return
else
  data.reason = 9
  return
end</code>
        <annotations>
          <_logging_behavior>
            <_exclude/>
          </_logging_behavior>
          <_context_data_analysis>
            <probes/>
          </_context_data_analysis>
        </annotations>
      </manipulate>
      <choose mode="exclusive" label="">
        <alternative eid="e1" condition="data.reason.to_i == 0">
          <_probability>
            <_probability_min/>
            <_probability_max/>
            <_probability_avg/>
          </_probability>
          <manipulate id="a8" label="Movement Unavailable: Has No Movement Left">
            <code>data.title = "#, you do not have any movement left!"
data.message = "Please wait to select another action..."
data.move = false</code>
            <annotations>
              <_logging_behavior>
                <_exclude/>
              </_logging_behavior>
              <_context_data_analysis>
                <probes/>
              </_context_data_analysis>
            </annotations>
          </manipulate>
        </alternative>
        <alternative eid="e2" condition="data.reason.to_i == 1">
          <_probability>
            <_probability_min/>
            <_probability_max/>
            <_probability_avg/>
          </_probability>
          <manipulate id="a1" label="Movement Unavailable: Player is Grappled">
            <code>data.title = "#, you are grappled so you cannot move!"
data.message = "Please wait to select another action..."
data.move = false</code>
            <annotations>
              <_logging_behavior>
                <_exclude/>
              </_logging_behavior>
              <_context_data_analysis>
                <probes/>
              </_context_data_analysis>
            </annotations>
          </manipulate>
        </alternative>
        <otherwise>
          <manipulate id="a7" label="Movement Available: Has Movement &amp; Not Grappled">
            <code>data.title = "#, you may take your movement!"
data.message = "You can only move a number of cells allowed by your movement..."
data.move = true</code>
            <annotations>
              <_logging_behavior>
                <_exclude/>
              </_logging_behavior>
              <_context_data_analysis>
                <probes/>
              </_context_data_analysis>
            </annotations>
          </manipulate>
        </otherwise>
      </choose>
    </description>
  </description>
  <transformation>
    <description type="copy"/>
    <dataelements type="none"/>
    <endpoints type="none"/>
  </transformation>
</testset>