            <code>
              <signal/>
              <prepare/>
              <finalize output="result"># ----- Helpers -----

def safe_id(h)
  return "" unless h
  (h["id"] || "").to_s
end

# --- Set Player Target ---
data.current_player["target"] = result["selection"]
target_id = data.current_player["target"].to_s
data.target = data.initiative_order.find do |ent|
  ent["type"] == "enemy" &amp;&amp; safe_id(ent) == target_id
end

# --- Check Player Chosen Action for Sneak/Reckless Attack ---
if data.current_player["chosen_action"].to_i == 2 || data.current_player["chosen_action"].to_i == 8
  data.reason = 6
end

# --- Set Player Max Roll ---
data.max_roll = 20 + data.current_player["attack_bonus"].to_i</finalize>
