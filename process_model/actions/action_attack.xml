        <code># --- Sync into Initiative Order ---

data.initiative_order.map! do |ent|
  if ent &amp;&amp; ent["type"] == "player" &amp;&amp; (ent["id"] || "").to_s == (data.current_player["id"]).to_s
    data.current_player
  else
    ent
  end
end

# --- Sync into Player Data ---

data.player_data.map! do |pl|
  if pl &amp;&amp; (pl["id"] || "").to_s == (data.current_player["id"]).to_s
    data.current_player
  else
    pl
  end
end</code>
