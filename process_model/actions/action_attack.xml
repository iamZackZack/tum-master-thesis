              <manipulate id="a3" label="Handle Damage">
                <code># ----- Helpers -----

def safe_id(h)
  return "" unless h
  (h["id"] || "").to_s
end

# ----- Variables -----

chosen_action = data.current_player["chosen_action"].to_i
skills = data.current_player["skills"]
skill = skills.find { |s| s["id"].to_i == chosen_action }
target_id = data.current_player["target"].to_s
damage_roll = data.current_player["damage_roll"].to_i
dice_count = skill["no_of_dice"].to_i
die_type = skill["die"].to_s
target = data.target

# ---- Apply damage to target hp &amp; Track Target "damaged_by" ----

old_hp = target["hp"].to_i
new_hp = old_hp - damage_roll
new_hp = 0 if new_hp &lt; 0
target["hp"] = new_hp

damaged_by = target["damaged_by"]
attacker_id = safe_id(data.current_player)
damaged_by &lt;&lt; attacker_id unless damaged_by.include?(attacker_id)
target["damaged_by"] = damaged_by

# --- Track Activation for the Enemy ---
target["activation"] = 0

# ----- Sync Target into Initiative Order -----

data.initiative_order.map! do |ent|
  if ent["type"] == "enemy" &amp;&amp; safe_id(ent) == target_id
    target
  else
    ent
  end
end

# ----- Generate Title &amp; Message -----

attacker_name = data.current_player["title"].to_s
target_name = target["title"].to_s
data.title = "#{attacker_name} deals #{damage_roll} damage to #{target_name}!"
data.message = "Please wait..."</code>
