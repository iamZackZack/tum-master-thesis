      <choose mode="exclusive" label="">
        <alternative condition="data.rejuvenate == true">
          <manipulate id="a5" label="Rule: Action &amp; Resources Used for Attack">
            <code>chosen_action = data.current_player["chosen_action"].to_i
skills = data.current_player["skills"]
skill = skills.find { |s| s["id"].to_i == chosen_action }

# ----- Set Available Action to False -----

data.current_player["action_available"] = false

# ----- Subtract Resource Costs from Player -----

m_cost = skill["m_cost"].to_i
a_cost = skill["a_cost"].to_i

mana = data.current_player["mana"].to_i
adr = data.current_player["adrenaline"].to_i

data.current_player["mana"] = [mana - m_cost, 0].max
data.current_player["adrenaline"] = [adr  - a_cost, 0].max</code>
