              <manipulate id="a8" label="Handle Healing">
                <code># ----- Helpers -----

def safe_id(h)
  return "" unless h
  (h["id"] || "").to_s
end

# ----- Variables -----

chosen_action = data.current_player["chosen_action"].to_i
skills = data.current_player["skills"]
skill = skills.find { |s| s["id"].to_i == chosen_action }
target_id = data.current_player["target"].to_s
healing = data.current_player["damage_roll"].to_i

# ---- Find Target in Initiative Order ----

target = data.initiative_order.find do |ent|
  ent["type"] == "player" &amp;&amp; safe_id(ent) == target_id
end

# ---- Handle Healing ----

old_hp = target["hp"].to_i
max_hp = target["max_hp"].to_i
new_hp = [old_hp + healing, max_hp].min
target["hp"] = new_hp

if safe_id(data.current_player) == target_id
  data.current_player["hp"] = new_hp
end

# ----- Sync Target into Initiative Order -----

data.initiative_order.map! do |ent|
  if ent["type"] == "player" &amp;&amp; safe_id(ent) == target_id
    target
  else
    ent
  end
end

# ----- Sync Target into Player Data -----

data.player_data.map! do |pl|
  if safe_id(pl) == target_id
    target
  else
    pl
  end
end

# ----- Generate Title &amp; Message -----

healer_name = data.current_player["title"].to_s
target_name = target["title"].to_s
data.title = "#{healer_name} heals #{target_name} for #{healing} hit points!"
data.message = "Please wait..."</code>
