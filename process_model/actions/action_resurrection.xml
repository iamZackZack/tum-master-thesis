          <manipulate id="a3" label="Handle Resurrection">
            <code># --- Helpers ---
def find_cell(game_state, r, c)
  game_state.flatten.find do |cell|
    g = cell["global"]
    g &amp;&amp; g[0].to_i == r.to_i &amp;&amp; g[1].to_i == c.to_i
  end
end

def free_spawn_cell(game_state, r, c, actor_id)
  base = find_cell(game_state, r, c)
  return base if base &amp;&amp;
                 !base["terrainID"].nil? &amp;&amp;
                 (base["occupied"].nil? || base["occupied"].to_s == actor_id.to_s)

  candidates = []
  (-1..1).each do |dc|
    (-1..1).each do |dr|
      next if dr == 0 &amp;&amp; dc == 0
      nr = r.to_i + dr
      nc = c.to_i + dc
      cell = find_cell(game_state, nr, nc)
      next unless cell
      next if cell["terrainID"].nil?
      next unless cell["occupied"].nil?
      candidates &lt;&lt; cell
    end
  end
  return nil if candidates.empty?
  candidates.sample
end

def safe_id(h)
  return "" unless h
  (h["id"] || "").to_s
end

# --- Variables ---

action_id = data.current_player["chosen_action"].to_i
target_id = data.current_player["target"].to_s

# --- Find Target in Player Data ---

target = data.player_data.find { |pl| (pl["id"] || "").to_s == target_id }
conds = target["conditions"].map(&amp;:to_s)

# --- Perform the Resurrection ---

conds.delete("dead")
target["conditions"] = conds
max_hp = target["max_hp"].to_i
target["hp"] = max_hp

# --- Put Player Back on Grid

pos = target["position"]
if pos.is_a?(Array) &amp;&amp; pos.size == 2
  r, c = pos
  spawn_cell = free_spawn_cell(data.game_state, r, c, target_id)
  if spawn_cell
    spawn_cell["occupied"] = target_id
    g = spawn_cell["global"]
    target["position"] = [g[0].to_i, g[1].to_i] if g.is_a?(Array) &amp;&amp; g.size == 2
  end
end

# --- Insert Target into Initiative Order ---

existing = false
data.initiative_order.map! do |ent|
  if ent["type"] == "player" &amp;&amp; (ent["id"] || "").to_s == target_id
    existing = true
    target
  else
    ent
  end
end

data.initiative_order &lt;&lt; target unless existing

# --- Sync Target with Player Data ---

data.player_data.map! do |pl|
  if safe_id(pl) == target_id
    target
  else
    pl
  end
end

# --- Sort Initiative Order by Descending Order ---

data.initiative_order.sort_by! { |ent| -((ent["initiative"] || 0).to_i) }

# --- Adjust Round ---

cp_init = data.current_player["initiative"].to_i
target_init = target["initiative"].to_i

if target_init &gt;= cp_init
  data.round = (data.round).to_i + 1
end

# ----------------------- 6) Success messaging &amp; cleanup -----------------------

title = target["title"]
data.title = "#{title} has been resurrected and returns at full health!"
data.message = "Please wait..."</code>
