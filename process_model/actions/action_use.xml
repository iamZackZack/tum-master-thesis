          <manipulate id="a3" label="Handle Potion Effect &amp; Equipment">
            <code># --- Variables ---
choice = data.choice.to_s
roll = data.player_roll.to_i
equip = data.current_player["equipment"]

# --- Apply Potion Effect ---

data.title = "#{choice} used!"

case choice
when "Healing Potion"
  hp = data.current_player["hp"].to_i
  max_hp = data.current_player["max_hp"].to_i
  data.current_player["hp"] = [hp + roll, max_hp].min
  data.message = "You regained #{roll} hit points..."
when "Mana Potion"
  mana = data.current_player["mana"].to_i
  max_mana = data.current_player["max_mana"].to_i
  data.current_player["mana"] = [mana + roll, max_mana].min
  data.message = "You regained #{roll} mana points..."
when "Adrenaline Potion"
  adr = data.current_player["adrenaline"].to_i
  max_adr = data.current_player["max_adrenaline"].to_i
  data.current_player["adrenaline"] = [adr + roll, max_adr].min
  data.message = "You regained #{roll} adrenaline points..."
when "Stability Potion"
  ins = data.current_player["insanity"].to_i
  data.current_player["insanity"] = [ins - roll, 0].max
  data.message = "You reduced your insanity by #{roll} points..."
end

# --- Remove Potion from Equipment ---
prefix =
  case choice
  when "Healing Potion" then "healing"
  when "Mana Potion" then "mana"
  when "Adrenaline Potion" then "adrenaline"
  when "Stability Potion" then "stability"
  end

matches = equip.select { |e| e.to_s.start_with?(prefix) }

latest = matches.max_by do |id|
  id.to_s.sub(prefix, "").to_i
end

equip.delete_at(equip.rindex(latest))
data.current_player["equipment"] = equip

# --- Consume Bonus Action ---
data.current_player["b_action_available"] = false</code>
