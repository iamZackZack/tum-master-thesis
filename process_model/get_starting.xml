            <label>Instruct Player to Select a Position</label>
            <color/>
            <arguments>
              <type>set</type>
              <lx>6</lx>
              <ly>1</ly>
              <x_amount>3</x_amount>
              <y_amount>1</y_amount>
              <button/>
              <style/>
              <urls>
                <urls_item>
                  <lang>de-at</lang>
                  <url>https://lehre.bpm.in.tum.de/~ge87max/instruction/instruction.html</url>
                </urls_item>
              </urls>
              <default>
                <title>!data.title</title>
                <message>!data.message</message>
                <player_id>!data.player_id</player_id>
              </default>
            </arguments>
          </parameters>
          <code>
            <signal/>
            <prepare>endpoints.frames_display += attributes.fid</prepare>
            <finalize output="result"/>
            <update output="result"/>
            <rescue output="result"/>
          </code>
          <annotations>
            <_generic/>
            <_logging_behavior>
              <_exclude/>
              <_include/>
            </_logging_behavior>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
            <code>
              <description/>
            </code>
          </documentation>
        </call>
        <call id="a1" endpoint="waitMovement">
          <parameters>
            <label>Wait for Position</label>
            <color/>
            <method>:post</method>
            <arguments/>
          </parameters>
          <code>
            <signal/>
            <prepare/>
            <finalize output="result">data.result = result["position"]
data.checking = true</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
          <annotations>
            <_generic/>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
            <code>
              <description/>
            </code>
          </documentation>
        </call>
        <manipulate id="a4" label="Validate Position">
          <code># --- Helper ---
def find_cell(game_state, r, c)
  game_state.flatten.find do |cell|
    g = cell["global"]
    g &amp;&amp; g[0].to_i == r.to_i &amp;&amp; g[1].to_i == c.to_i
  end
end

# --- Find Cell and Cell Items ---
r, c = data.result
cell = find_cell(data.game_state, r, c)

terrain  = cell["terrainID"]
effect = cell["effect"]
occupied = cell["occupied"]

if terrain.nil?
  data.reason = 1
  return
elsif effect.nil? 
  data.reason = 2
  return
elsif !occupied.nil?
  data.reason = 3
  return
else 
  # Is it a Starting Cell?
  char_id = effect.to_s.sub(/S\z/, "").downcase
  chosen_template = data.character_template.find do |t|
    (t["id"] || "").to_s.downcase == char_id
  end
  unless chosen_template
    data.reason = 4
    return
  end
end</code>
          <annotations>
            <_logging_behavior>
              <_exclude/>
            </_logging_behavior>
            <_context_data_analysis>
              <probes/>
            </_context_data_analysis>
          </annotations>
        </manipulate>
        <choose mode="exclusive" label="">
          <alternative condition="data.reason.to_i == 1">
            <manipulate id="a2" label="Reason: Terrain Not Revealed">
              <code>data.message = "Please select a cell that has been revealed..."</code>
              <annotations>
                <_logging_behavior>
                  <_exclude/>
                </_logging_behavior>
                <_context_data_analysis>
