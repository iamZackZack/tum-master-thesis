      <manipulate id="a1" label="Check for Enemy Deaths">
        <code># --- Helper ---

def clear_occupancy(game, actor_id)
  game.each do |row|
    next unless row.is_a?(Array)
    row.each do |cell|
      next unless cell.is_a?(Hash)
      occ = cell["occupied"]
      cell["occupied"] = nil if occ &amp;&amp; occ.to_s == actor_id.to_s
    end
  end
end

# --- Variables ---

new_order = []
round_adjust = 0
data.slain = []

data.initiative_order.each do |ent|
  next unless ent.is_a?(Hash)
  if ent["type"].to_s == "enemy" &amp;&amp; ent["hp"].to_i &lt;= 0
    clear_occupancy(data.game_state, ent["id"].to_s)
    data.slain &lt;&lt; { "title" =&gt; ent["title"].to_s, "reason" =&gt; "hp" }

    if ent["initiative"].to_i &gt; data.current_player["initiative"].to_i
      round_adjust = round_adjust - 1
    end

    next
  end

  new_order &lt;&lt; ent
end

data.initiative_order = new_order

# --- Apply Round Adjustment ---
data.round = [data.round.to_i + round_adjust, 0 ].max</code>
