      <manipulate id="a3" label="Check for Player Deaths">
        <code># --- Helpers ---

def clear_occupancy(game_state, actor_id)
  return unless game_state.is_a?(Array) &amp;&amp; actor_id

  game_state.each do |row|
    next unless row.is_a?(Array)
    row.each do |cell|
      next unless cell.is_a?(Hash)
      occ = cell["occupied"]
      cell["occupied"] = nil if occ &amp;&amp; occ.to_s == actor_id.to_s
    end
  end
end

def copy_hash!(target, source)
  target.clear
  source.each { |k, v| target[k] = v }
end

# --- Variables ---

new_order = []
round_adjust = 0
cur_init = data.current_player["initiative"].to_i

cur_id = data.current_player["id"].to_s

data.initiative_order.each do |ent|
  next unless ent.is_a?(Hash)

  # keep enemies as-is (enemy removal happens in the enemy script)
  if ent["type"].to_s != "player"
    new_order &lt;&lt; ent
    next
  end

  died_by_hp = (ent["hp"].to_i &lt;= 0)
  died_by_insanity = (ent["insanity"].to_i &gt;= ent["max_insanity"].to_i)

  if died_by_hp || died_by_insanity
    reason = died_by_insanity ? "insanity" : "hp"

    # GM Gains Fear
    gm_factor = data.configuration["gm_factor"].to_i
    data.configuration["fear"] = data.configuration["fear"].to_i + (2 * gm_factor)

    # Add "dead" condition
    conds = ent["conditions"].map(&amp;:to_s)
    conds &lt;&lt; "dead" unless conds.include?("dead")
    ent["conditions"] = conds

    # Copy into player_data
    pd = data.player_data.find { |pl| pl["id"].to_s == ent["id"].to_s }
    if pd
      copy_hash!(pd, ent)
    end

    # Clear grid occupancy
    clear_occupancy(data.game_state, ent["id"].to_s)

    # Track slain entity
    data.slain &lt;&lt; { "title" =&gt; ent["title"].to_s, "reason" =&gt; reason }

    # Adjust round if needed
    if ent["initiative"].to_i &gt; cur_init
      round_adjust = round_adjust - 1 
    end

    # If current_player died, remove
    if cur_id == ent["id"].to_s
      data.current_player = nil
    end

    next
  end
  new_order &lt;&lt; ent
end

data.initiative_order = new_order
data.round = [data.round.to_i + round_adjust, 0].max</code>
