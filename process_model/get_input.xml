<testset xmlns="http://cpee.org/ns/properties/2.0">
  <executionhandler>ruby</executionhandler>
  <dataelements>
    <checking/>
    <message/>
    <result/>
    <title/>
    <player_id/>
    <min/>
    <max/>
  </dataelements>
  <endpoints>
    <frames_display>https-put://{cpee.org}/out/frames/</frames_display>
  </endpoints>
  <attributes>
    <info>get_input</info>
    <guarded>none</guarded>
    <modeltype>Signavio</modeltype>
    <theme>dataflow</theme>
    <guarded_id/>
    <creator>Christine Ashcreek</creator>
    <author>Christine Ashcreek</author>
    <model_uuid>91bcfe32-14cd-4c82-8e3c-d462ea06742b</model_uuid>
    <model_version/>
    <design_dir>Teaching.dir/Prak.dir/TUM-Prak-24-WS.dir/Zeka_Dizdar.dir/</design_dir>
    <design_stage>development</design_stage>
    <fid>{gridsanddragons}/</fid>
  </attributes>
  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">
      <loop mode="post_test" condition="data.checking">
        <call id="a1" endpoint="frames_display">
          <parameters>
            <label>Clear Message Display Box</label>
            <color/>
            <arguments>
              <type>set</type>
              <lx>6</lx>
              <ly>3</ly>
              <x_amount>3</x_amount>
              <y_amount>2</y_amount>
              <button/>
              <style/>
              <urls/>
              <default/>
            </arguments>
          </parameters>
          <code>
            <signal/>
            <prepare>endpoints.frames_display += attributes.fid</prepare>
            <finalize output="result"/>
            <update output="result"/>
            <rescue output="result"/>
          </code>
          <annotations>
            <_generic/>
            <_logging_behavior>
              <_exclude/>
              <_include/>
            </_logging_behavior>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
            <code>
              <description/>
            </code>
          </documentation>
        </call>
        <call id="a3" endpoint="frames_display">
          <parameters>
            <label>Display Input Box</label>
            <color/>
            <arguments>
              <type>wait</type>
              <lx>6</lx>
              <ly>3</ly>
              <x_amount>3</x_amount>
              <y_amount>2</y_amount>
              <button/>
              <style>https://lehre.bpm.in.tum.de/~ge87max/input/input.css</style>
              <urls>
                <urls_item>
                  <lang>de-at</lang>
                  <url>https://lehre.bpm.in.tum.de/~ge87max/input/input.html</url>
                </urls_item>
              </urls>
              <default>
                <title>!data.title</title>
                <message>!data.message</message>
                <player_id>!data.player_id</player_id>
              </default>
            </arguments>
          </parameters>
          <code>
            <signal/>
            <prepare>endpoints.frames_display += attributes.fid</prepare>
            <finalize output="result">data.result = result["value"]
data.checking = true</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
          <annotations>
            <_generic/>
            <_logging_behavior>
              <_exclude/>
              <_include/>
            </_logging_behavior>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
            <code>
              <description/>
            </code>
          </documentation>
        </call>
        <choose eid="e2" mode="exclusive" label="">
          <alternative eid="e3" condition="data.result.to_s.match?(/\A\d+\z/)">
            <choose mode="exclusive" label="">
              <alternative condition="data.result.to_i &lt; data.min.to_i">
                <manipulate id="a2" label="Reason: Input Value Too Small">
                  <code>data.message = "Please enter a number between #{data.min} and #{data.max}!"</code>
                  <annotations>
                    <_logging_behavior>
                      <_exclude/>
                    </_logging_behavior>
                    <_context_data_analysis>
                      <probes/>
                    </_context_data_analysis>
                  </annotations>
                </manipulate>
                <_probability>
                  <_probability_min/>
                  <_probability_max/>
                  <_probability_avg/>
                </_probability>
              </alternative>
              <alternative condition="data.result.to_i &gt; data.max.to_i">
                <manipulate id="a5" label="Reason: Input Value Too Large">
                  <code>data.message = "Please enter a number between #{data.min} and #{data.max}!"</code>
                  <annotations>
                    <_logging_behavior>
                      <_exclude/>
                    </_logging_behavior>
                    <_context_data_analysis>
                      <probes/>
                    </_context_data_analysis>
                  </annotations>
                </manipulate>
                <_probability>
                  <_probability_min/>
                  <_probability_max/>
                  <_probability_avg/>
                </_probability>
              </alternative>
              <otherwise>
                <manipulate id="a7" label="Reason: Input Value Between Range">
                  <code>data.checking = false</code>
                  <annotations>
                    <_logging_behavior>
                      <_exclude/>
                    </_logging_behavior>
                    <_context_data_analysis>
                      <probes/>
                    </_context_data_analysis>
                  </annotations>
                </manipulate>
              </otherwise>
            </choose>
            <_probability>
              <_probability_min/>
              <_probability_max/>
              <_probability_avg/>
            </_probability>
          </alternative>
          <otherwise>
            <manipulate id="a4" label="Reason: Input Value Not a Valid Integer">
              <code>data.message = "Please enter a valid integer number!"</code>
              <annotations>
                <_logging_behavior>
                  <_exclude/>
                </_logging_behavior>
                <_context_data_analysis>
                  <probes/>
                </_context_data_analysis>
              </annotations>
            </manipulate>
          </otherwise>
        </choose>
        <call id="a6" endpoint="frames_display">
          <parameters>
            <label>Clear Input Display Box</label>
            <color/>
            <arguments>
              <type>set</type>
              <lx>6</lx>
              <ly>3</ly>
              <x_amount>3</x_amount>
              <y_amount>2</y_amount>
              <button/>
              <style/>
              <urls/>
              <default/>
            </arguments>
          </parameters>
          <code>
            <signal/>
            <prepare>endpoints.frames_display += attributes.fid</prepare>
            <finalize output="result"/>
            <update output="result"/>
            <rescue output="result"/>
          </code>
          <annotations>
            <_generic/>
            <_logging_behavior>
              <_exclude/>
              <_include/>
            </_logging_behavior>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
            <code>
              <description/>
            </code>
          </documentation>
        </call>
        <_probability>
          <_probability_min/>
          <_probability_max/>
          <_probability_avg/>
        </_probability>
        <_annotations>
          <_logging_behavior>
            <_iteration/>
          </_logging_behavior>
        </_annotations>
      </loop>
    </description>
  </description>
  <transformation>
    <description type="copy"/>
    <dataelements type="none"/>
    <endpoints type="none"/>
  </transformation>
</testset>