      <manipulate id="a1" label="Determine Enemy Spawn">
        <code># --- Helpers ---

def manhattan(a, b)
  return 9999 unless a.is_a?(Array) &amp;&amp; b.is_a?(Array) &amp;&amp; a.size == 2 &amp;&amp; b.size == 2
  (a[0].to_i - b[0].to_i).abs + (a[1].to_i - b[1].to_i).abs
end

def deep_copy(obj)
  Marshal.load(Marshal.dump(obj))
end

def next_enemy_number(order, prefix)
  nums = order.select { |e| e.is_a?(Hash) &amp;&amp; e["type"].to_s == "enemy" &amp;&amp; e["id"].to_s.start_with?(prefix) }
             .map do |e|
               m = e["id"].to_s.match(/#{Regexp.escape(prefix)}(\d+)/)
               m ? m[1].to_i : 0
             end
  (nums.max || 0) + 1
end

# --- Variables ---

grid  = data.game_state
players = data.initiative_order.select { |e| e.is_a?(Hash) &amp;&amp; e["type"].to_s == "player" }
enemies = data.initiative_order.select { |e| e.is_a?(Hash) &amp;&amp; e["type"].to_s == "enemy" }

# --- Max Enemy Cap ---

max_enemies = data.configuration["max_enemies"].to_i
if enemies.size &gt;= max_enemies
  data.reason = 1
  return
end

# --- Is there Fear to spend? ---

fear = data.configuration["fear"].to_i
if fear &lt; 1
  data.reason = 2
  return
end

# --- Chance to Spawn ---

if rand(0.0..100.0) &gt;= data.configuration["enemy_spawn_chance"].to_f
  data.reason = 3
  return
end

# --- Get Mimic Template ---

mimic_template = data.enemy_template.find { |e| e["id"] == "mimic#" }

# --- Select Random Player and Spawn Enemy around them ---

player = players.sample
p_pos  = player["position"]

player_terrain = nil
grid.each do |row|
  next unless row.is_a?(Array)
  row.each do |cell|
    next unless cell.is_a?(Hash)
    g = cell["global"]
    next unless g.is_a?(Array) &amp;&amp; g.size == 2
    if g[0].to_i == p_pos[0].to_i &amp;&amp; g[1].to_i == p_pos[1].to_i
      player_terrain = cell["terrainID"]
      break
    end
  end
  break if player_terrain
end

forbidden = ["barbarianE","clericE","rogueE","wizardE"]
candidates = []

grid.each do |row|
  next unless row.is_a?(Array)
  row.each do |cell|
    next unless cell.is_a?(Hash)
    next if cell["terrainID"].nil?
    next unless cell["terrainID"].to_s == player_terrain.to_s

    next unless cell["occupied"].nil?
    next if forbidden.include?(cell["effect"].to_s)
    next unless cell["global"].is_a?(Array) &amp;&amp; cell["global"].size == 2

    gpos = [cell["global"][0].to_i, cell["global"][1].to_i]
    next unless manhattan(p_pos, gpos) &lt;= 2

    candidates &lt;&lt; cell
  end
end

if candidates.empty?
  data.reason = 4
  return
end

spawn_cell = candidates.sample
spawn_g = spawn_cell["global"]
spawn_pos = [spawn_g[0].to_i, spawn_g[1].to_i]

# --- Generate Enemy Stat Block ---

next_num = next_enemy_number(data.initiative_order, "mimic")
enemy_id    = "mimic#{next_num}"
enemy_title = "Mimic #{next_num}"

init_bonus = data.configuration["enemy_init_bonus"].to_i

new_enemy = deep_copy(mimic_template)

new_enemy["id"] = enemy_id
new_enemy["number"] = next_num
new_enemy["title"] = enemy_title
new_enemy["hp"] = data.configuration["enemy_hp"].to_i
new_enemy["ac"] = data.configuration["enemy_ac"].to_i
new_enemy["initiative"] = rand(1..20) + init_bonus
new_enemy["position"] = spawn_pos

# --- Occupy Cell in the Grid with Enemy ---

spawn_cell["occupied"] = enemy_id
data.game_state = grid
data.spawn_enemy = true
data.new_enemy = new_enemy

# --- Insert Enemy into Initiative Order and Re-Sort

data.initiative_order &lt;&lt; new_enemy
data.initiative_order.sort_by! { |e| -(e["initiative"].to_i) }

# ---------- Fear cost ----------

data.configuration["fear"] = [fear - 1, 0].max

# --- Adjust Round if Spawned Enemy has Higher Initiative than Current Player ---

if new_enemy["initiative"].to_i &gt;= data.current_player["initiative"].to_i
  data.round = data.round.to_i + 1
end</code>
