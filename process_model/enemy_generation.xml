      <manipulate id="a3" label="Determine Enemy Despawn(s)">
        <code># --- Helpers ---

def clear_occupancy_for_actor(game_state, actor_id)
  return unless game_state.is_a?(Array) &amp;&amp; actor_id

  game_state.each do |row|
    next unless row.is_a?(Array)
    row.each do |cell|
      next unless cell.is_a?(Hash)
      occ = cell["occupied"]
      cell["occupied"] = nil if occ &amp;&amp; occ.to_s == actor_id.to_s
    end
  end
end

# --- Variables ---

order = data.initiative_order
game  = data.game_state

new_order = []
round_adjust = 0
removed_count = 0
despawned = []

# --- Despawn Enemies with Activation &gt;= 3 ---

order.each do |ent|
  next unless ent.is_a?(Hash)

  if ent["type"].to_s == "enemy" &amp;&amp; ent["activation"].to_i &gt;= 3
    clear_occupancy_for_actor(game, ent["id"].to_s)

    if ent["initiative"].to_i &gt; data.current_player["initiative"].to_i
      round_adjust -= 1
    end

    removed_count += 1
    despawned &lt;&lt; ent

    next
  end

  new_order &lt;&lt; ent
end

# --- Enable De-Spawn UI ---

if removed_count &gt; 0
  data.despawn_enemy = true
end

data.despawned = despawned

# --- Update Initiative Order ---
data.initiative_order = new_order
data.initiative_order.sort_by! { |e| -(e["initiative"].to_i) }

# --- Update Game State ---
data.game_state = game

# Refund Fear per De-spawned Enemy
data.configuration["fear"] = data.configuration["fear"].to_i + removed_count

# Adjust Round per De-spawned Enemy
data.round = [data.round.to_i + round_adjust, 0].max</code>
